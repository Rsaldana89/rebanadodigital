# Archivo de ejemplo de variables de entorno
# Copia este archivo como .env y completa los valores antes de ejecutar la aplicación

# Configuración de la base de datos
DB_HOST=localhost
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=chc_rebanado
DB_PORT=3306

# Puerto donde se ejecutará la aplicación
PORT=3000

# Clave para la sesión
SESSION_SECRET=secreto_super_seguro