<%- include('../partials/header', { title: 'Reportes', user: user, success_msg: success_msg, error_msg: error_msg }) %>

<div class="page-header">
  <div class="row align-items-center g-3">
    <div class="col-lg-8">
      <div class="page-kicker">Consulta</div>
      <h1 class="page-title">Reportes de vales</h1>
      <p class="page-subtitle">Cada resultado representa un pedido; el CSV incluye un renglón por producto.</p>
    </div>
  </div>
</div>

<div class="form-shell mb-4">
  <form class="row g-3" method="get" action="/reportes">
    <div class="col-md-3">
      <label class="form-label">Estado</label>
      <select name="estado" class="form-select">
        <% ['Todos','Pendiente','Rebanando','Listo','Entregado','Cancelado'].forEach(option => { %>
          <option value="<%= option %>" <%= filtros.estado === option ? 'selected' : '' %>><%= option %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-3">
      <label class="form-label">Fecha inicio</label>
      <input type="date" name="fecha_inicio" value="<%= filtros.fecha_inicio || '' %>" class="form-control">
    </div>
    <div class="col-md-3">
      <label class="form-label">Fecha fin</label>
      <input type="date" name="fecha_fin" value="<%= filtros.fecha_fin || '' %>" class="form-control">
    </div>
    <div class="col-md-3 d-flex align-items-end gap-2 flex-wrap">
      <button class="btn btn-primary" type="submit"><i class="bi bi-search me-1"></i>Filtrar</button>
      <button class="btn btn-soft" type="submit" name="exportar" value="csv"><i class="bi bi-download me-1"></i>Exportar productos</button>
    </div>
  </form>
</div>

<div class="content-card data-table-card">
  <div class="d-flex justify-content-between align-items-center gap-3 mb-3 flex-wrap">
    <div>
      <h2 class="section-title mb-1">Resultados</h2>
      <p class="section-subtitle"><%= vales.length %> vale(s) encontrado(s).</p>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table table-modern align-middle command-report-table">
      <thead>
        <tr>
          <th>Folio / Pedido</th>
          <th>Cliente</th>
          <th>Productos</th>
          <th>Prioridad</th>
          <th>Estado</th>
          <th>Entrega</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (!vales.length) { %>
          <tr>
            <td colspan="7">
              <div class="empty-state py-3"><i class="bi bi-inbox"></i><div>No hay registros para los filtros seleccionados.</div></div>
            </td>
          </tr>
        <% } %>
        <% vales.forEach(v => { %>
          <tr>
            <td><strong><%= v.folio %></strong><% if (v.numero_pedido) { %><div class="small text-muted">Pedido <%= v.numero_pedido %></div><% } %></td>
            <td><%= v.cliente %></td>
            <td>
              <div class="report-products-summary">
                <strong><%= v.total_productos || 0 %> producto(s)</strong>
                <% (v.productos || []).slice(0, 3).forEach(item => { %><span><%= item.producto %></span><% }) %>
                <% if ((v.productos || []).length > 3) { %><span>+ <%= v.productos.length - 3 %> más</span><% } %>
              </div>
            </td>
            <td><%= v.prioridad %></td>
            <td><%= v.estado %></td>
            <td><%= v.fecha_entrega_fmt || '' %></td>
            <td><a href="/vales/<%= v.id %>" class="btn btn-sm btn-soft">Detalle</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
