<%- include('../partials/header', { title: 'Reportes', user: user, success_msg: success_msg, error_msg: error_msg }) %>

<div class="page-header">
  <div class="row align-items-center g-3">
    <div class="col-lg-8">
      <div class="page-kicker">Consulta</div>
      <h1 class="page-title">Reportes de vales</h1>
      <p class="page-subtitle">Filtra la información operativa y, si lo necesitas, exporta a CSV.</p>
    </div>
  </div>
</div>

<div class="form-shell mb-4">
  <form class="row g-3" method="get" action="/reportes">
    <div class="col-md-3">
      <label class="form-label">Estado</label>
      <select name="estado" class="form-select">
        <option value="Todos" <%= filtros.estado === 'Todos' ? 'selected' : '' %>>Todos</option>
        <option value="Pendiente" <%= filtros.estado === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
        <option value="Rebanando" <%= filtros.estado === 'Rebanando' ? 'selected' : '' %>>Rebanando</option>
        <option value="Listo" <%= filtros.estado === 'Listo' ? 'selected' : '' %>>Listo</option>
        <option value="Entregado" <%= filtros.estado === 'Entregado' ? 'selected' : '' %>>Entregado</option>
        <option value="Cancelado" <%= filtros.estado === 'Cancelado' ? 'selected' : '' %>>Cancelado</option>
      </select>
    </div>
    <div class="col-md-3">
      <label class="form-label">Fecha inicio</label>
      <input type="date" name="fecha_inicio" value="<%= filtros.fecha_inicio || '' %>" class="form-control">
    </div>
    <div class="col-md-3">
      <label class="form-label">Fecha fin</label>
      <input type="date" name="fecha_fin" value="<%= filtros.fecha_fin || '' %>" class="form-control">
    </div>
    <div class="col-md-3 d-flex align-items-end gap-2 flex-wrap">
      <button class="btn btn-primary" type="submit"><i class="bi bi-search me-1"></i>Filtrar</button>
      <button class="btn btn-soft" type="submit" name="exportar" value="csv"><i class="bi bi-download me-1"></i>Exportar CSV</button>
    </div>
  </form>
</div>

<div class="content-card data-table-card">
  <div class="d-flex justify-content-between align-items-center gap-3 mb-3 flex-wrap">
    <div>
      <h2 class="section-title mb-1">Resultados</h2>
      <p class="section-subtitle"><%= vales.length %> registro(s) encontrado(s).</p>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table table-modern align-middle">
      <thead>
        <tr>
          <th>Folio</th>
          <th>Cliente</th>
          <th>Producto</th>
          <th>Cantidad</th>
          <th>Prioridad</th>
          <th>Estado</th>
          <th>Entrega</th>
        </tr>
      </thead>
      <tbody>
        <% if (!vales.length) { %>
          <tr>
            <td colspan="7">
              <div class="empty-state py-3">
                <i class="bi bi-inbox"></i>
                <div>No hay registros para los filtros seleccionados.</div>
              </div>
            </td>
          </tr>
        <% } %>
        <% vales.forEach(v => { %>
          <tr>
            <td><strong><%= v.folio %></strong></td>
            <td><%= v.cliente %></td>
            <td><%= v.producto %></td>
            <td><%= v.cantidad %></td>
            <td><%= v.prioridad %></td>
            <td><%= v.estado %></td>
            <td><%= new Date(v.fecha_entrega).toISOString().substring(0,10) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
