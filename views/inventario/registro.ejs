<%- include('../partials/header', { title: 'Registro de inventario', user: user, success_msg: success_msg, error_msg: error_msg }) %>

<div class="page-header">
  <div class="row align-items-center g-3">
    <div class="col-lg-8">
      <div class="page-kicker">Cierre de día</div>
      <h1 class="page-title">Registro de inventario</h1>
      <p class="page-subtitle">Captura existencias, sobrantes, merma y observaciones del cierre operativo.</p>
    </div>
  </div>
</div>

<div class="form-shell">
  <form action="/inventario/registro" method="post" class="row g-3">
    <div class="col-md-3">
      <label class="form-label">Fecha</label>
      <input type="date" name="fecha" class="form-control" required>
    </div>
    <div class="col-md-3">
      <label class="form-label">SKU</label>
      <input type="text" name="sku" class="form-control" placeholder="Código del producto" required>
    </div>
    <div class="col-md-6">
      <label class="form-label">Producto</label>
      <input type="text" name="producto" class="form-control" placeholder="Nombre del producto" required>
    </div>
    <div class="col-md-3">
      <label class="form-label">Cantidad disponible</label>
      <input type="number" step="0.01" min="0" name="cantidad_disponible" class="form-control" placeholder="0.00">
    </div>
    <div class="col-md-3">
      <label class="form-label">Producto extra</label>
      <input type="number" step="0.01" min="0" name="producto_extra" class="form-control" placeholder="0.00">
    </div>
    <div class="col-md-3">
      <label class="form-label">Sobrante</label>
      <input type="number" step="0.01" min="0" name="sobrante" class="form-control" placeholder="0.00">
    </div>
    <div class="col-md-3">
      <label class="form-label">Merma</label>
      <input type="number" step="0.01" min="0" name="merma" class="form-control" placeholder="0.00">
    </div>
    <div class="col-12">
      <label class="form-label">Observaciones</label>
      <textarea name="observaciones" class="form-control" rows="3" placeholder="Comentarios del cierre, incidencias o notas importantes."></textarea>
    </div>
    <div class="col-12 d-flex flex-wrap gap-2 pt-2">
      <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Guardar registro</button>
      <a href="/dashboard" class="btn btn-soft"><i class="bi bi-arrow-left me-1"></i>Volver al dashboard</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
