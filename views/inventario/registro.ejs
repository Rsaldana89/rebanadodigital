<%- include('../partials/header', { title: 'Cierre de día', user: user, success_msg: success_msg, error_msg: error_msg }) %>

<div class="page-header">
  <div class="row align-items-center g-3">
    <div class="col-lg-8">
      <div class="page-kicker">Operación</div>
      <h1 class="page-title">Cierre de día</h1>
      <p class="page-subtitle mb-0">Registra existencias, sobrantes y merma del producto rebanado.</p>
    </div>
  </div>
</div>

<div class="form-shell">
  <form action="/inventario/registro" method="post" class="row g-3">
    <div class="col-lg-5">
      <section class="form-section">
        <div class="form-section-title"><i class="bi bi-box-seam"></i>Producto</div>
        <div class="row g-3">
          <div class="col-md-5">
            <label class="form-label">Fecha</label>
            <input type="date" name="fecha" class="form-control" data-default-today required>
          </div>
          <div class="col-md-7">
            <label class="form-label">SKU</label>
            <input type="text" name="sku" class="form-control" placeholder="Código del producto" required>
          </div>
          <div class="col-12">
            <label class="form-label">Producto</label>
            <input type="text" name="producto" class="form-control" placeholder="Nombre del producto" required>
          </div>
        </div>
      </section>
    </div>

    <div class="col-lg-7">
      <section class="form-section">
        <div class="form-section-title"><i class="bi bi-calculator"></i>Cantidades</div>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Disponible</label>
            <input type="number" step="0.01" min="0" name="cantidad_disponible" class="form-control" placeholder="0.00">
          </div>
          <div class="col-md-6">
            <label class="form-label">Producto extra</label>
            <input type="number" step="0.01" min="0" name="producto_extra" class="form-control" placeholder="0.00">
          </div>
          <div class="col-md-6">
            <label class="form-label">Sobrante</label>
            <input type="number" step="0.01" min="0" name="sobrante" class="form-control" placeholder="0.00">
          </div>
          <div class="col-md-6">
            <label class="form-label">Merma</label>
            <input type="number" step="0.01" min="0" name="merma" class="form-control" placeholder="0.00">
          </div>
        </div>
      </section>
    </div>

    <div class="col-12">
      <section class="form-section">
        <div class="form-section-title"><i class="bi bi-chat-left-text"></i>Observaciones</div>
        <textarea name="observaciones" class="form-control" rows="3" placeholder="Incidencias o comentarios del cierre."></textarea>
      </section>
    </div>

    <div class="col-12 d-flex flex-wrap gap-2 pt-2">
      <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-save me-1"></i>Guardar cierre</button>
      <a href="/dashboard" class="btn btn-soft btn-lg"><i class="bi bi-arrow-left me-1"></i>Volver</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
