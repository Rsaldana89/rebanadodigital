<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pantalla informativa | CHC Rebanado Digital</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/styles.css">
  <script>
    setTimeout(() => { window.location.reload(); }, 30000);
  </script>
</head>
<body class="tv-body">
  <div class="container-fluid py-4 px-lg-4">
    <div class="tv-panel">
      <div class="tv-header">
        <div class="tv-title-wrap">
          <span class="tv-brand-mark"><i class="bi bi-display"></i></span>
          <div>
            <h1 class="tv-title">CHC Rebanado Digital</h1>
            <p class="tv-subtitle">Pantalla informativa de seguimiento de vales</p>
          </div>
        </div>
        <div class="tv-meta">
          <div class="tv-meta-label">Actualización</div>
          <div class="tv-meta-value"><%= fecha.toLocaleDateString() %></div>
          <div class="tv-subtitle"><%= fecha.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) %></div>
        </div>
      </div>

      <div class="info-strip mb-4">
        <div class="info-pill">
          <div class="info-pill-label">Total visibles</div>
          <div class="info-pill-value"><%= vales.length %></div>
        </div>
        <div class="info-pill">
          <div class="info-pill-label">Estados</div>
          <div class="info-pill-value">Pendiente · Rebanando · Listo · Entregado · Cancelado</div>
        </div>
        <div class="info-pill">
          <div class="info-pill-label">Uso recomendado</div>
          <div class="info-pill-value">Monitor o TV en área operativa</div>
        </div>
      </div>

      <div class="tv-table-wrap">
        <table class="table-tv">
          <thead>
            <tr>
              <th>Folio</th>
              <th>Cliente</th>
              <th>Producto</th>
              <th>Prioridad</th>
              <th>Estado</th>
              <th>Entrega</th>
            </tr>
          </thead>
          <tbody>
            <% if (!vales.length) { %>
              <tr>
                <td colspan="6">
                  <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <div>No hay vales para mostrar en este momento.</div>
                  </div>
                </td>
              </tr>
            <% } %>
            <% vales.forEach(v => { %>
              <tr>
                <td class="folio-cell"><%= v.folio %></td>
                <td><%= v.cliente %></td>
                <td><%= v.producto %></td>
                <td>
                  <span class="priority-badge <%= v.prioridad === 'Alta' ? 'priority-high' : v.prioridad === 'Normal' ? 'priority-normal' : 'priority-low' %>">
                    <%= v.prioridad %>
                  </span>
                </td>
                <td>
                  <span class="status-chip <%= v.estado === 'Pendiente' ? 'status-pending' : v.estado === 'Rebanando' ? 'status-working' : v.estado === 'Listo' ? 'status-ready' : v.estado === 'Entregado' ? 'status-delivered' : 'status-cancelled' %>">
                    <%= v.estado %>
                  </span>
                </td>
                <td><%= new Date(v.fecha_entrega).toISOString().substring(0,10) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="text-end mt-2 text-muted small">Esta pantalla se actualiza automáticamente cada 30 segundos.</div>
    </div>
  </div>
</body>
</html>
