<%- include('../partials/header', { title: 'Crear vale', user: user, success_msg: success_msg, error_msg: error_msg }) %>

<div class="page-header">
  <div class="row align-items-center g-3">
    <div class="col-lg-8">
      <div class="page-kicker">Nuevo registro</div>
      <h1 class="page-title">Crear vale de rebanado</h1>
      <p class="page-subtitle mb-0">Captura únicamente los datos necesarios para enviar el vale al tablero.</p>
    </div>
    <div class="col-lg-4">
      <div class="header-actions justify-content-lg-end">
        <a href="/vales/tablero" class="btn btn-soft"><i class="bi bi-arrow-left me-1"></i>Volver a vales</a>
      </div>
    </div>
  </div>
</div>

<div class="form-shell">
  <form action="/vales/crear" method="post" class="row g-3">
    <div class="col-lg-6">
      <section class="form-section">
        <div class="form-section-title"><i class="bi bi-receipt"></i>Solicitud</div>
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label">Origen</label>
            <select name="origen" class="form-select" required>
              <option value="Manual" selected>Manual</option>
              <option value="Siclik">Siclik</option>
              <option value="Excel">Excel</option>
            </select>
          </div>
          <div class="col-md-8">
            <label class="form-label">Cliente / Ruta</label>
            <input type="text" name="cliente" class="form-control" placeholder="Ej. Ruta Norte o nombre del cliente" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Fecha de entrega</label>
            <input type="date" name="fecha_entrega" class="form-control" data-default-today required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Prioridad</label>
            <select name="prioridad" class="form-select" required>
              <option value="Alta">Alta</option>
              <option value="Normal" selected>Normal</option>
              <option value="Baja">Baja</option>
            </select>
          </div>
        </div>
      </section>
    </div>

    <div class="col-lg-6">
      <section class="form-section">
        <div class="form-section-title"><i class="bi bi-box-seam"></i>Producto</div>
        <div class="row g-3">
          <div class="col-md-5">
            <label class="form-label">SKU</label>
            <input type="text" name="sku" class="form-control" placeholder="Código del producto" required>
          </div>
          <div class="col-md-7">
            <label class="form-label">Producto</label>
            <input type="text" name="producto" class="form-control" placeholder="Nombre del producto" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Cantidad</label>
            <input type="number" step="0.01" min="0" name="cantidad" class="form-control" placeholder="0.00" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Presentación</label>
            <input type="text" name="presentacion" class="form-control" placeholder="250 g, 500 g, 1 kg" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Rebanado</label>
            <select name="tipo_rebanado" class="form-select" required>
              <option value="Estándar">Estándar</option>
              <option value="Grueso">Grueso</option>
              <option value="Otro">Otro</option>
            </select>
          </div>
        </div>
      </section>
    </div>

    <div class="col-12">
      <section class="form-section">
        <div class="form-section-title"><i class="bi bi-chat-left-text"></i>Observaciones</div>
        <textarea name="observaciones" class="form-control" rows="3" placeholder="Instrucciones especiales o comentarios para Rebanado."></textarea>
      </section>
    </div>

    <div class="col-12 d-flex flex-wrap gap-2 pt-2">
      <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check2-circle me-1"></i>Crear vale</button>
      <a href="/vales/tablero" class="btn btn-soft btn-lg"><i class="bi bi-x-lg me-1"></i>Cancelar</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
