<%
  const compactSuccessMsg = /^Bienvenido/i.test(success_msg || '') ? null : success_msg;
  const canCreateVale = typeof can === 'function' && can('vales.create');
  const canEditVale = typeof can === 'function' && can('vales.edit');
%>
<%- include('../partials/header', {
  title: 'Vales',
  user: user,
  success_msg: compactSuccessMsg,
  error_msg: error_msg,
  compactAlerts: true,
  bodyClass: 'tablero-dark-body tablero-operator-body'
}) %>

<%
  const estadoInfo = {
    Todos: { cls: 'all', icon: 'bi-grid-1x2' },
    Pendiente: { cls: 'pending', icon: 'bi-hourglass-split', accion: 'Iniciar rebanado', accionCorta: 'Iniciar', siguiente: 'Rebanando', btnIcon: 'bi-play-circle' },
    Rebanando: { cls: 'working', icon: 'bi-gear-wide-connected', accion: 'Marcar listo', accionCorta: 'Marcar listo', siguiente: 'Listo', btnIcon: 'bi-check2-circle' },
    Listo: { cls: 'ready', icon: 'bi-check2-circle', accion: 'Entregar', accionCorta: 'Entregar', siguiente: 'Entregado', btnIcon: 'bi-truck' },
    Entregado: { cls: 'delivered', icon: 'bi-truck' },
    Cancelado: { cls: 'cancelled', icon: 'bi-x-circle' }
  };
  const prioridadInfo = {
    Alta: { cls: 'high', icon: 'bi-exclamation-circle-fill' },
    Normal: { cls: 'normal', icon: 'bi-flag' },
    Baja: { cls: 'low', icon: 'bi-arrow-down-circle' }
  };
  const estadosOrden = ['Pendiente','Rebanando','Listo','Entregado','Cancelado'];
  const allVales = estadosOrden.flatMap(est => (estados[est] || []));
  const activos = (estados.Pendiente.length || 0) + (estados.Rebanando.length || 0) + (estados.Listo.length || 0);
  const returnUrl = `/vales/tablero?fecha=${encodeURIComponent(filtroFecha)}`;
%>

<section class="operator-commandbar" aria-labelledby="operatorBoardTitle">
  <div class="operator-command-main">
    <div class="operator-kicker">Comandas de rebanado</div>
    <div class="operator-title-line">
      <h1 id="operatorBoardTitle">Vales por pedido</h1>
      <span class="operator-total"><strong><%= activos %></strong> activos</span>
      <% if (overdueCount > 0) { %>
        <span class="operator-overdue"><i class="bi bi-exclamation-triangle-fill"></i><strong><%= overdueCount %></strong> atrasado<%= overdueCount === 1 ? '' : 's' %></span>
      <% } %>
    </div>
    <div class="operator-date-line">
      <i class="bi bi-calendar3"></i><span><%= filtroFechaDisplay %></span>
      <span class="operator-date-separator">·</span>
      <i class="bi bi-clock"></i><span><%= horaActual %></span>
    </div>
  </div>

  <div class="operator-command-actions">
    <% if (canCreateVale) { %>
      <a href="/vales/crear" class="operator-screen-link operator-new-link" title="Crear una nueva comanda">
        <i class="bi bi-plus-lg"></i><span>Nuevo vale</span>
      </a>
    <% } %>
    <a href="/pantalla?fecha=<%= filtroFecha %>" target="_blank" class="operator-screen-link" title="Abrir pantalla de almacén">
      <i class="bi bi-display"></i><span>Pantalla</span>
    </a>
  </div>
</section>

<section class="operator-tools" aria-label="Filtros del tablero">
  <div class="operator-tools-top">
    <form method="get" action="/vales/tablero" class="operator-date-form">
      <label for="fecha" class="visually-hidden">Fecha de entrega</label>
      <span class="operator-control-label"><i class="bi bi-calendar-event"></i>Entrega</span>
      <input type="date" id="fecha" name="fecha" value="<%= filtroFecha %>" class="form-control">
      <button type="submit" class="operator-icon-button" title="Aplicar fecha" aria-label="Aplicar fecha"><i class="bi bi-arrow-right"></i></button>
      <a href="/vales/tablero" class="operator-today-link">Hoy</a>
    </form>

    <div class="ops-search operator-search">
      <i class="bi bi-search"></i>
      <input type="search" id="opsSearch" placeholder="Buscar folio, pedido, cliente, producto o SKU" aria-label="Buscar vales">
    </div>
  </div>

  <div class="operator-filter-row" role="group" aria-label="Filtrar vales por estado">
    <button class="operator-filter-pill is-all active" type="button" data-filter-status="Todos" aria-pressed="true">
      <span>Todos</span><strong><%= allVales.length %></strong>
    </button>
    <% estadosOrden.forEach(function(est){ const info = estadoInfo[est]; %>
      <button id="<%= est %>" class="operator-filter-pill is-<%= info.cls %>" type="button" data-filter-status="<%= est %>" aria-pressed="false">
        <span><%= est %></span><strong><%= estados[est].length %></strong>
      </button>
    <% }) %>
    <span class="operator-visible-count"><strong id="visibleOpsCount"><%= allVales.length %></strong> visibles · <span id="currentFilterLabel">Todos</span></span>
  </div>
</section>

<section class="ops-list" id="opsList">
  <% if (!allVales.length) { %>
    <div class="empty-state empty-state-card">
      <i class="bi bi-inbox"></i>
      <div>No hay vales programados ni atrasados visibles para <strong><%= filtroFechaDisplay %></strong>.</div>
    </div>
  <% } %>

  <% allVales.forEach(function(vale){
    const e = estadoInfo[vale.estado] || estadoInfo.Pendiente;
    const p = prioridadInfo[vale.prioridad] || prioridadInfo.Normal;
    const fechaEntrega = vale.fecha_entrega_fmt || (vale.fecha_entrega ? new Date(vale.fecha_entrega).toISOString().substring(0,10) : '');
    const fechaEntregaDisplay = fechaEntrega ? fechaEntrega.split('-').reverse().join('/') : '';
    const atrasoTexto = vale.days_late === 1 ? '1 día' : `${vale.days_late} días`;
    const searchText = `${vale.folio} ${vale.numero_pedido || ''} ${vale.cliente} ${vale.productos_busqueda || ''} ${vale.prioridad} ${vale.estado} ${vale.is_overdue ? 'atrasado retraso' : ''}`.toLowerCase();
    const allowedStates = vale.allowed_states || [];
    const canAdvance = e.siguiente ? allowedStates.includes(e.siguiente) : false;
    const canCancel = !['Entregado','Cancelado'].includes(vale.estado) && allowedStates.includes('Cancelado');
    const showMoreMenu = canCancel || canEditVale;
  %>
    <article class="op-vale-card op-vale-<%= e.cls %> <%= vale.is_overdue ? 'op-vale-overdue' : '' %> op-vale-operator command-ticket" data-status="<%= vale.estado %>" data-search="<%= searchText %>">
      <div class="operator-card-head">
        <div class="operator-card-title">
          <span class="op-folio"><%= vale.folio %></span>
          <% if (vale.numero_pedido) { %><span class="command-order-number">Pedido <%= vale.numero_pedido %></span><% } %>
          <span class="status-chip status-<%= e.cls %>"><i class="bi <%= e.icon %>"></i><%= vale.estado %></span>
        </div>
        <div class="operator-card-flags">
          <span class="operator-priority priority-<%= p.cls %>" title="Prioridad <%= vale.prioridad %>"><i class="bi <%= p.icon %>"></i><%= vale.prioridad %></span>
          <% if (vale.is_overdue) { %>
            <span class="operator-late"><i class="bi bi-exclamation-triangle-fill"></i><%= atrasoTexto %> tarde</span>
          <% } %>
        </div>
      </div>

      <div class="operator-card-content">
        <div class="operator-client command-client"><i class="bi bi-person-workspace"></i><strong><%= vale.cliente %></strong></div>

        <div class="command-product-list" aria-label="Productos de la comanda">
          <% (vale.productos || []).forEach(function(item, productIndex){ %>
            <div class="command-product-line">
              <span class="command-product-qty"><strong><%= item.cantidad %></strong> <%= item.presentacion %></span>
              <span class="command-product-name"><%= item.producto %></span>
              <span class="command-product-cut"><%= item.tipo_rebanado %></span>
              <span class="command-product-sku"><%= item.sku %></span>
              <% if (item.observaciones) { %><span class="command-product-note" title="<%= item.observaciones %>"><i class="bi bi-chat-left-text"></i><%= item.observaciones %></span><% } %>
            </div>
          <% }) %>
          <% if (!(vale.productos || []).length) { %>
            <div class="command-product-line command-product-missing"><i class="bi bi-exclamation-triangle"></i>Sin productos registrados</div>
          <% } %>
        </div>

        <div class="operator-facts command-facts" aria-label="Datos del vale">
          <span><strong><%= vale.total_productos || 0 %></strong> producto<%= vale.total_productos === 1 ? '' : 's' %></span>
          <span>Entrega <strong><%= fechaEntregaDisplay %></strong></span>
        </div>

        <% if (vale.observaciones) { %>
          <div class="operator-note" title="<%= vale.observaciones %>"><i class="bi bi-chat-left-text"></i><span><%= vale.observaciones %></span></div>
        <% } %>
      </div>

      <div class="operator-card-actions">
        <% if (e.siguiente && canAdvance) { %>
          <form method="post" action="/vales/<%= vale.id %>/estado" class="operator-primary-form">
            <input type="hidden" name="return_url" value="<%= returnUrl %>">
            <input type="hidden" name="nuevo_estado" value="<%= e.siguiente %>">
            <button type="submit" class="operator-primary-action state-<%= e.cls %>">
              <i class="bi <%= e.btnIcon %>"></i><span><%= e.accionCorta || e.accion %></span>
            </button>
          </form>
        <% } else if (vale.estado === 'Listo') { %>
          <div class="operator-ready-state"><i class="bi bi-check2-circle"></i><span>Listo para entrega</span></div>
        <% } else if (e.siguiente) { %>
          <div class="operator-locked-state" title="No tienes permiso para esta acción"><i class="bi bi-lock-fill"></i><span>Acción restringida</span></div>
        <% } else { %>
          <div class="operator-finished-state"><i class="bi <%= e.icon %>"></i><span><%= vale.estado %></span></div>
        <% } %>

        <a href="/vales/<%= vale.id %>" class="operator-detail-action" title="Ver comanda completa" aria-label="Ver detalle del vale <%= vale.folio %>">
          <i class="bi bi-eye"></i><span>Detalle</span>
        </a>

        <% if (showMoreMenu) { %>
          <details class="operator-more-menu">
            <summary title="Más acciones" aria-label="Más acciones"><i class="bi bi-three-dots-vertical"></i></summary>
            <div class="operator-more-panel command-more-panel">
              <% if (canEditVale) { %>
                <a href="/vales/<%= vale.id %>/editar"><i class="bi bi-pencil-square"></i>Editar comanda</a>
              <% } %>
              <% if (canCancel) { %>
                <form method="post" action="/vales/<%= vale.id %>/estado" data-confirm="¿Cancelar este vale completo?">
                  <input type="hidden" name="return_url" value="<%= returnUrl %>">
                  <input type="hidden" name="nuevo_estado" value="Cancelado">
                  <button type="submit"><i class="bi bi-x-circle"></i>Cancelar vale</button>
                </form>
              <% } %>
            </div>
          </details>
        <% } %>
      </div>
    </article>
  <% }) %>

  <div id="opsEmptyFilter" class="empty-state empty-state-card d-none">
    <i class="bi bi-search"></i>
    <div>No hay vales que coincidan con el filtro.</div>
  </div>
</section>

<%- include('../partials/footer') %>
