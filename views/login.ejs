<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar sesión | CHC Rebanado Digital</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="login-shell d-flex align-items-center">
  <div class="container py-4 py-lg-5">
    <div class="row justify-content-center">
      <div class="col-12 col-xl-10">
        <div class="login-card">
          <div class="row g-0 align-items-stretch">
            <div class="col-lg-5 login-side">
              <div class="login-panel h-100 d-flex flex-column justify-content-between">
                <div>
                  <div class="d-flex align-items-center gap-3 mb-4">
                    <span class="brand-mark"><i class="bi bi-grid-1x2-fill"></i></span>
                    <div>
                      <h1 class="h3 mb-1 fw-bold">CHC Rebanado Digital</h1>
                      <p class="mb-0 text-white-50">Control visual de vales para Rebanado y CEDIS</p>
                    </div>
                  </div>
                  <p class="mb-0 text-white-50">
                    Plataforma operativa diseñada para trabajar con rapidez, claridad y seguimiento visual en tiempo real.
                  </p>
                  <ul class="login-feature-list">
                    <li><i class="bi bi-check2-circle"></i><span>Tablero visual por estados para operación diaria.</span></li>
                    <li><i class="bi bi-check2-circle"></i><span>Pantalla informativa legible en TV o monitor.</span></li>
                    <li><i class="bi bi-check2-circle"></i><span>Creación, seguimiento y cierre de vales desde web.</span></li>
                  </ul>
                </div>
                <div class="login-footer-note text-white-50">
                  <i class="bi bi-shield-check me-1"></i>
                  Acceso para usuarios autorizados de CHC.
                </div>
              </div>
            </div>
            <div class="col-lg-7 bg-white">
              <div class="login-panel h-100 d-flex flex-column justify-content-center">
                <div class="mb-4">
                  <div class="page-kicker">Bienvenido</div>
                  <h2 class="page-title mb-2">Inicia sesión</h2>
                  <p class="page-subtitle">Ingresa con tu usuario y contraseña para acceder al sistema.</p>
                </div>
                <% if (error_msg) { %>
                  <div class="alert alert-danger d-flex align-items-center gap-2"><i class="bi bi-exclamation-triangle-fill"></i><span><%= error_msg %></span></div>
                <% } %>
                <% if (success_msg) { %>
                  <div class="alert alert-success d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill"></i><span><%= success_msg %></span></div>
                <% } %>
                <form action="/login" method="post" class="row g-3">
                  <div class="col-12">
                    <label for="username" class="form-label">Usuario</label>
                    <div class="input-icon-group">
                      <span class="input-icon"><i class="bi bi-person"></i></span>
                      <input type="text" class="form-control" id="username" name="username" placeholder="Escribe tu usuario" required>
                    </div>
                  </div>
                  <div class="col-12">
                    <label for="password" class="form-label">Contraseña</label>
                    <div class="input-icon-group">
                      <span class="input-icon"><i class="bi bi-lock"></i></span>
                      <input type="password" class="form-control" id="password" name="password" placeholder="Escribe tu contraseña" required>
                    </div>
                  </div>
                  <div class="col-12 pt-2">
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                      <i class="bi bi-box-arrow-in-right me-1"></i>Ingresar al sistema
                    </button>
                  </div>
                </form>
                <div class="mt-4 login-footer-note">
                  Vista pensada para tablet, escritorio y operación diaria.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
