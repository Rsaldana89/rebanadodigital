<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar sesión | CHC Rebanado Digital</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/institutional.css">
</head>
<body class="login-shell d-flex align-items-center">
  <div class="container py-4 py-lg-5">
    <div class="row justify-content-center">
      <div class="col-12 col-xl-10">
        <div class="login-card">
          <div class="row g-0 align-items-stretch">
            <div class="col-lg-5 login-side">
              <div class="login-panel h-100 d-flex flex-column justify-content-between position-relative">
                <div class="position-relative" style="z-index:1;">
                  <div class="d-flex align-items-center gap-3 mb-4">
                    <span class="brand-monogram brand-monogram-lg">CHC</span>
                    <div>
                      <h1 class="h3 mb-1 fw-bold">Rebanado Digital</h1>
                      <p class="mb-0 text-white-50">Cremería Hermanos Coronel</p>
                    </div>
                  </div>

                  <div class="login-flow-heading">
                    <div class="login-flow-kicker">Flujo operativo del vale</div>
                    <h2 class="h4 fw-bold mb-2">Del pedido a la entrega</h2>
                    <p class="mb-4 text-white-50">Cada vale avanza por cuatro etapas. El tablero muestra dónde se encuentra y cuál es la siguiente acción.</p>
                  </div>

                  <div class="login-flow" aria-label="Flujo operativo: Pendiente, Rebanando, Listo y Entregado">
                    <div class="login-flow-step">
                      <span class="login-flow-number">1</span>
                      <div><strong>Pendiente</strong><small>Solicitud por iniciar</small></div>
                    </div>
                    <div class="login-flow-connector"><i class="bi bi-arrow-down"></i></div>
                    <div class="login-flow-step">
                      <span class="login-flow-number">2</span>
                      <div><strong>Rebanando</strong><small>Pedido en preparación</small></div>
                    </div>
                    <div class="login-flow-connector"><i class="bi bi-arrow-down"></i></div>
                    <div class="login-flow-step">
                      <span class="login-flow-number">3</span>
                      <div><strong>Listo</strong><small>Preparado para entrega</small></div>
                    </div>
                    <div class="login-flow-connector"><i class="bi bi-arrow-down"></i></div>
                    <div class="login-flow-step">
                      <span class="login-flow-number">4</span>
                      <div><strong>Entregado</strong><small>Proceso concluido</small></div>
                    </div>
                  </div>
                </div>

                <div class="login-footer-note text-white-50 position-relative mt-4" style="z-index:1;">
                  <i class="bi bi-shield-check me-1"></i>
                  Acceso exclusivo para personal autorizado.
                </div>
              </div>
            </div>

            <div class="col-lg-7 login-form-side">
              <div class="login-panel h-100 d-flex flex-column justify-content-center">
                <div class="mb-4">
                  <div class="login-eyebrow"><i class="bi bi-person-check"></i>Acceso al sistema</div>
                  <h2 class="page-title mb-2">Bienvenido</h2>
                  <p class="page-subtitle">Ingresa tus credenciales para continuar.</p>
                </div>

                <% if (error_msg) { %>
                  <div class="alert alert-danger d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i><span><%= error_msg %></span>
                  </div>
                <% } %>
                <% if (success_msg) { %>
                  <div class="alert alert-success d-flex align-items-center gap-2">
                    <i class="bi bi-check-circle-fill"></i><span><%= success_msg %></span>
                  </div>
                <% } %>

                <form action="/login" method="post" class="row g-3" id="loginForm">
                  <div class="col-12">
                    <label for="username" class="form-label">Usuario</label>
                    <div class="input-icon-group">
                      <span class="input-icon"><i class="bi bi-person"></i></span>
                      <input type="text" class="form-control" id="username" name="username" placeholder="Escribe tu usuario" autocomplete="username" required autofocus data-login-username>
                    </div>
                  </div>
                  <div class="col-12">
                    <label for="password" class="form-label">Contraseña</label>
                    <div class="input-icon-group password-input-group">
                      <span class="input-icon"><i class="bi bi-lock"></i></span>
                      <input type="password" class="form-control" id="password" name="password" placeholder="Escribe tu contraseña" autocomplete="current-password" required data-password-input>
                      <button type="button" class="password-toggle" data-password-toggle aria-label="Mostrar contraseña" aria-pressed="false">
                        <i class="bi bi-eye"></i>
                      </button>
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="remember-access">
                      <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" value="1" id="rememberLogin" data-remember-login>
                        <label class="form-check-label" for="rememberLogin">Recordar usuario y contraseña en este equipo</label>
                      </div>
                      <small>Se guardará únicamente en este navegador.</small>
                    </div>
                  </div>
                  <div class="col-12 pt-1">
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                      <i class="bi bi-box-arrow-in-right me-1"></i>Ingresar
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
