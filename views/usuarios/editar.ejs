<%- include('../partials/header', { title: 'Editar usuario', user: user, success_msg: success_msg, error_msg: error_msg }) %>

<div class="page-header">
  <div class="page-kicker">Administración</div>
  <h1 class="page-title">Editar usuario</h1>
  <p class="page-subtitle">Actualiza la información del acceso seleccionado.</p>
</div>

<div class="form-shell">
  <form action="/usuarios/<%= usuario.id %>/editar" method="post" class="row g-3">
    <div class="col-md-6">
      <label class="form-label">Nombre</label>
      <input type="text" name="name" class="form-control" value="<%= usuario.name %>" required>
    </div>
    <div class="col-md-6">
      <label class="form-label">Usuario</label>
      <input type="text" name="username" class="form-control" value="<%= usuario.username %>" required>
    </div>
    <div class="col-md-6">
      <label class="form-label">Contraseña</label>
      <input type="text" name="password" class="form-control" value="<%= usuario.password %>" required>
    </div>
    <div class="col-md-6">
      <label class="form-label">Rol</label>
      <select name="role" class="form-select" required>
        <option value="administrador" <%= usuario.role === 'administrador' ? 'selected' : '' %>>Administrador</option>
        <option value="cedis" <%= usuario.role === 'cedis' ? 'selected' : '' %>>CEDIS</option>
        <option value="rebanado" <%= usuario.role === 'rebanado' ? 'selected' : '' %>>Rebanado</option>
        <option value="almacen" <%= usuario.role === 'almacen' ? 'selected' : '' %>>Almacén</option>
      </select>
    </div>
    <div class="col-12">
      <div class="form-check mt-2">
        <input type="checkbox" name="active" value="1" class="form-check-input" id="activo" <%= usuario.active ? 'checked' : '' %>>
        <label for="activo" class="form-check-label">Usuario activo</label>
      </div>
    </div>
    <div class="col-12 d-flex flex-wrap gap-2 pt-2">
      <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Actualizar usuario</button>
      <a href="/usuarios" class="btn btn-soft"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
