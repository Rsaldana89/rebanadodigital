<%- include('../partials/header', { title: 'Permisos de usuario', user: user, success_msg: success_msg, error_msg: error_msg }) %>

<div class="page-header">
  <div class="row align-items-center g-3">
    <div class="col-lg-8">
      <div class="page-kicker">Excepción individual</div>
      <h1 class="page-title"><%= usuario.name %></h1>
      <p class="page-subtitle mb-0">Rol base: <strong><%= usuario.role %></strong>. “Heredar” usa la configuración general del rol.</p>
    </div>
    <div class="col-lg-4">
      <div class="header-actions justify-content-lg-end">
        <a href="/permisos" class="btn btn-soft"><i class="bi bi-arrow-left me-1"></i>Volver</a>
      </div>
    </div>
  </div>
</div>

<div class="content-card">
  <form method="post" action="/permisos/usuario/<%= usuario.id %>">
    <div class="permission-user-list">
      <% let currentCategory = ''; %>
      <% permissions.forEach(permission => { %>
        <% if (currentCategory !== permission.category) { currentCategory = permission.category; %>
          <div class="permission-user-category"><%= permission.category %></div>
        <% } %>
        <div class="permission-user-row">
          <div>
            <div class="permission-name"><%= permission.name %></div>
            <div class="permission-description"><%= permission.description %></div>
          </div>
          <div class="permission-user-control">
            <div class="role-base-indicator <%= permission.roleAllowed ? 'is-allowed' : 'is-denied' %>">
              Rol: <%= permission.roleAllowed ? 'Permitido' : 'Bloqueado' %>
            </div>
            <select name="u__<%= permission.code %>" class="form-select permission-override-select">
              <option value="inherit" <%= permission.override === 'inherit' ? 'selected' : '' %>>Heredar del rol</option>
              <option value="allow" <%= permission.override === 'allow' ? 'selected' : '' %>>Permitir para este usuario</option>
              <option value="deny" <%= permission.override === 'deny' ? 'selected' : '' %>>Bloquear para este usuario</option>
            </select>
          </div>
        </div>
      <% }) %>
    </div>
    <div class="d-flex justify-content-end mt-4">
      <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Guardar excepciones</button>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
